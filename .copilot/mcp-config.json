{
  "mcpServers": {
    "Azure": {
      "command": "npx",
      "args": [
        "-y",
        "@azure/mcp@latest",
        "server",
        "start"
      ]
    },
    "EXAMPLE-github": {
      "command": "npx",
      "args": [
        "-y",
        "@anthropic/github-mcp-server"
      ],
      "env": {
        "GITHUB_TOKEN": "${GITHUB_TOKEN}"
      }
    }
  }
}
