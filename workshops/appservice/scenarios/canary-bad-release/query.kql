// Investigation for the canary-bad-release scenario.
// 1) Which role instance (slot) is failing /products?
AppRequests
| where TimeGenerated > ago(30m)
| where Url contains "/products"
| summarize total = count(), failures = countif(Success == false or toint(ResultCode) >= 500) by AppRoleInstance
| extend failureRate = todouble(failures) / total
| order by failureRate desc

// 2) Root cause — the regression surfaces as a SQL exception on the canary instance.
